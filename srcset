# :command.parse_requirements
parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        srcset_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.dependencies_filter
  missing_deps=
  # :dependency.filter
  if ! command -v magick >/dev/null 2>&1; then
    printf "missing dependency: imagemagick\n" >&2
    printf "%s\n\n" "run 'brew insall imagemagick' on macos or 'sudo apt install imagemagick' on linux" >&2
    missing_deps=1
  else
    deps['imagemagick']="$(command -v magick | head -n1)"
  fi

  if [[ -n $missing_deps ]]; then
    exit 1
  fi

  # :command.command_filter
  action="root"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      # :flag.case
      --png | -p)

        # :flag.case_no_arg
        args['--png']=1
        shift
        ;;

      # :flag.case
      --large | -l)

        # :flag.case_no_arg
        args['--large']=1
        shift
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        # :argument.case
        if [[ -z ${args['input']+x} ]]; then
          args['input']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

}

